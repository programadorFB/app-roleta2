// src/hooks/useInactivityTimeout.js
import { useEffect, useRef } from 'react';

const INACTIVITY_LIMIT_MS = 90 * 60 * 1000; // 90 minutos

/**
 * Monitora atividade do usuário e faz logout automático após inatividade.
 * Só ativa quando há gameUrl e o usuário está autenticado.
 */
export function useInactivityTimeout(isActive, onTimeout) {
  const timeoutRef = useRef(null);

  useEffect(() => {
    if (!isActive) {
      if (timeoutRef.current) clearTimeout(timeoutRef.current);
      return;
    }

    const reset = () => {
      if (timeoutRef.current) clearTimeout(timeoutRef.current);
      timeoutRef.current = setTimeout(() => {
        onTimeout();
        alert('Sessão encerrada por inatividade. Faça login novamente.');
      }, INACTIVITY_LIMIT_MS);
    };

    reset();

    const handlers = {
      mousemove: reset,
      keydown: reset,
      touchstart: reset,
      focus: reset,
      blur: () => clearTimeout(timeoutRef.current),
    };

    // Registra eventos de atividade
    document.addEventListener('mousemove', handlers.mousemove);
    document.addEventListener('keydown', handlers.keydown);
    document.addEventListener('touchstart', handlers.touchstart);
    window.addEventListener('focus', handlers.focus);
    window.addEventListener('blur', handlers.blur);

    return () => {
      clearTimeout(timeoutRef.current);
      document.removeEventListener('mousemove', handlers.mousemove);
      document.removeEventListener('keydown', handlers.keydown);
      document.removeEventListener('touchstart', handlers.touchstart);
      window.removeEventListener('focus', handlers.focus);
      window.removeEventListener('blur', handlers.blur);
    };
  }, [isActive, onTimeout]);
}